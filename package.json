{
  "name": "careercaveman",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run build:sidecar && npm run build:frontend && npm run build:tauri-check",
    "build:frontend": "tsc -p tsconfig.app.json && vite build",
    "build:sidecar": "tsc -p sidecar/tsconfig.json",
    "build:tauri-check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "test": "npm run test:frontend && npm run test:sidecar && npm run test:rust",
    "test:frontend": "vitest run src/lib",
    "test:sidecar": "vitest run sidecar/src",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "typecheck": "tsc -p tsconfig.app.json && tsc -p sidecar/tsconfig.json",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "clsx": "^2.1.1",
    "imapflow": "^1.3.3",
    "lucide-react": "^0.475.0",
    "mailparser": "^3.9.8",
    "nodemailer": "^8.0.7",
    "playwright-core": "^1.60.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22"
  }
}
