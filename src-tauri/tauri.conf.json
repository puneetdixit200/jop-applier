{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CareerCaveman",
  "version": "0.1.0",
  "identifier": "com.careercaveman.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CareerCaveman",
        "width": 1180,
        "height": 780,
        "minWidth": 860,
        "minHeight": 620,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.png"
    ],
    "targets": [
      "dmg",
      "appimage",
      "deb",
      "msi",
      "nsis"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFCOTk2MDQ2N0ZEQ0ZBN0EKUldSNit0eC9SbUNaR3dvc3RNWFJ3N3ErK2ZpRmJmYnJNdWJxaW1PNmtTUXhJWXFSYWJPaExzU00K",
      "endpoints": [
        "https://github.com/puneetdixit200/jop-applier/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
